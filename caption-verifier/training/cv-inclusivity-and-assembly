    "# Load grammar scores\n",
    "grammar_df = pd.read_csv(GRAMMAR_SCORES)\n",
    "\n",
    "# Score full dataset for tone and inclusivity\n",
    "# Uses the best single fold's weights directly — bypasses the weight-averaged\n",
    "# soup model which loses discriminative ability when folds converge to different\n",
    "# loss basins.  best_fold.pth was saved into each model_dir before merge_folds\n",
    "# deleted the individual fold files.\n",
    "def infer_classifier(texts, model_dir, base_model_name, cfg, threshold, label):\n",
    "    tokenizer  = AutoTokenizer.from_pretrained(model_dir)\n",
    "    ds         = CaptionDataset(texts, [0]*len(texts), tokenizer, cfg['max_len'])\n",
    "    loader     = DataLoader(ds, batch_size=cfg['batch']*2, shuffle=False, num_workers=0)\n",
    "\n",
    "    # Load base architecture, patch head structure, then restore trained weights\n",
    "    model = AutoModelForSequenceClassification.from_pretrained(\n",
    "        base_model_name, num_labels=1\n",
    "    ).to(device)\n",
    "    model = patch_classifier_head(model, dropout=cfg['dropout'])\n",
    "    best_pth = f'{model_dir}/best_fold.pth'\n",
    "    state    = torch.load(best_pth, map_location=device)\n",
    "    model.load_state_dict(state)\n",
    "    model    = model.float()\n",
    "    model.eval()\n",
    "    print(f'  [{label}] loaded best fold weights from {best_pth}')\n",
    "\n",
    "    probs = []\n",
    "    with torch.no_grad():\n",
    "        for batch in tqdm(loader, desc=label, leave=False):\n",
    "            logits = model(\n",
    "                input_ids=batch['input_ids'].to(device),\n",
    "                attention_mask=batch['attention_mask'].to(device)\n",
    "            ).logits.squeeze(-1)\n",
    "            probs.extend(np.nan_to_num(torch.sigmoid(logits).cpu().numpy(), nan=0.5))\n",
    "    release_memory(model, tokenizer, state)\n",
    "\n",
    "    raw    = np.array(probs)\n",
    "    dec    = (raw >= threshold).astype(int)\n",
    "    scaled = np.array([scale_score(p, threshold) for p in raw])\n",
    "    return raw, dec, scaled\n",
    "\n",
    "full_texts = df['text'].tolist()\n",
    "\n",
    "print('Scoring tone...')\n",
    "tone_raw, tone_dec, tone_scaled = infer_classifier(\n",
    "    full_texts,\n",
    "    model_dir        = TONE_MODEL_DIR,\n",
    "    base_model_name  = tone_art['config']['model'],\n",
    "    cfg              = tone_art['config'],\n",
    "    threshold        = tone_threshold,\n",
    "    label            = 'tone',\n",
    ")\n",
    "\n",
    "print('Scoring inclusivity...')\n",
    "incl_raw, incl_dec, incl_scaled = infer_classifier(\n",
    "    full_texts,\n",
    "    model_dir        = incl_model_dir,\n",
    "    base_model_name  = INCL_CONFIG['model'],\n",
    "    cfg              = INCL_CONFIG,\n",
    "    threshold        = incl_threshold,\n",
    "    label            = 'inclusivity',\n",
    ")\n",
    "\n",
    "# Merge everything\n",
    "df['tone_raw_score']        = tone_raw.round(4)\n",
    "df['tone_score']            = tone_scaled\n",
    "df['tone_decision']         = ['pass' if d == 1 else 'fail' for d in tone_dec]\n",
    "df['inclusivity_raw_score'] = incl_raw.round(4)\n",
    "df['inclusivity_score']     = incl_scaled\n",
    "df['inclusivity_decision']  = ['pass' if d == 1 else 'fail' for d in incl_dec]\n",
    "\n",
    "# Merge grammar scores in\n",
    "df = df.merge(\n",
    "    grammar_df[['text','grammar_raw_score','grammar_score','grammar_decision',\n",
    "                'grammar_corrected','grammar_comment','grammar_lt_errors']],\n",
    "    on='text', how='left',\n",
    ")\n",
    "\n",
    "score_cols    = ['grammar_score',     'tone_score',     'inclusivity_score']\n",
    "raw_cols      = ['grammar_raw_score', 'tone_raw_score', 'inclusivity_raw_score']\n",
    "decision_cols = ['grammar_decision',  'tone_decision',  'inclusivity_decision']\n",
    "# grammar_score is raw 0-1; tone and inclusivity are scaled 0-100.\n",
    "# Convert grammar to 0-100 for averaging, but keep the stored column as raw 0-1.\n",
    "df['overall_score'] = (\n",
    "    (df['grammar_score'] * 100 + df['tone_score'] + df['inclusivity_score']) / 3\n",
    ").round(1)\n",
    "\n",
    "out_cols = (['text','status','issue']\n",
    "            + raw_cols + score_cols + decision_cols\n",
    "            + ['overall_score','grammar_corrected','grammar_comment','grammar_lt_errors'])\n",
    "df[out_cols].to_csv(f'{SAVE_DIR}/final_scores.csv', index=False)\n",
    "print(f'\\nSaved final scores → {SAVE_DIR}/final_scores.csv')\n",
    "print('\\nMean scores by status:')\n",
    "display(df.groupby('status')[score_cols + ['overall_score']].mean().round(1))"
   ]
  },
