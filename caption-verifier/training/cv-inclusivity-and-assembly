    "import pickle, os, math\n",
    "\n",
    "# Redefine grammar_tier locally to avoid cross-kernel pickle issues\n",
    "def grammar_tier(score):\n",
    "    if score >= 0.75:\n",
    "        return 'pass'\n",
    "    elif score >= 0.50:\n",
    "        return 'needs revision'\n",
    "    return 'fail'\n",
    "\n",
    "# Redefine scale_score locally for tone/inclusivity\n",
    "def scale_score(raw_prob, threshold):\n",
    "    def _sig(x, lo, hi):\n",
    "        s = 1 / (1 + math.exp(-10 * (x - 0.5)))\n",
    "        return lo + (hi - lo) * s\n",
    "    if raw_prob >= threshold:\n",
    "        return round(_sig((raw_prob - threshold) / (1.0 - threshold + 1e-8), 70.0, 100.0), 1)\n",
    "    return round(_sig(raw_prob / (threshold + 1e-8), 0.0, 50.0), 1)\n",
    "\n",
    "with open(GRAMMAR_ARTEFACTS, 'rb') as f:\n",
    "    grammar_art = pickle.load(f)\n",
    "with open(TONE_ARTEFACTS, 'rb') as f:\n",
    "    tone_art = pickle.load(f)\n",
    "\n",
    "grammar_pass_threshold     = grammar_art['pass_threshold']\n",
    "grammar_revision_threshold = grammar_art['revision_threshold']\n",
    "tone_threshold             = tone_art['threshold']\n",
    "\n",
    "print(f'Grammar pass threshold     : {grammar_pass_threshold}')\n",
    "print(f'Grammar revision threshold : {grammar_revision_threshold}')\n",
    "print(f'Tone threshold             : {tone_threshold}')"
