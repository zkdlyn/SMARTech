    "        if running_mean is None:\n",
    "            running_mean = {k: v.clone().float() for k, v in state.items()}\n",
    "            float_keys   = {k for k, v in state.items() if v.dtype.is_floating_point}\n",
    "        else:\n",
    "            n = fold + 1\n",
    "            for key in float_keys:\n",
    "                running_mean[key] += (state[key].float() - running_mean[key]) / n\n",
    "        del state; gc.collect()\n",
    "        os.remove(path)\n",
    "        print(f'  Fold {fold+1} merged and deleted.')\n",
    "    return running_mean\n",
    "\n",
    "# Save best fold .pth BEFORE merge_folds deletes all fold files\n",
    "incl_best_fold_idx  = int(np.argmax(fold_aucs))\n",
    "incl_best_fold_path = f'{SAVE_DIR}/inclusivity_fold{incl_best_fold_idx+1}.pth'\n",
    "incl_best_fold_save = f'{SAVE_DIR}/inclusivity_best_fold.pth'\n",
    "shutil.copy(incl_best_fold_path, incl_best_fold_save)\n",
    "print(f'Best fold: {incl_best_fold_idx+1}  (AUC {fold_aucs[incl_best_fold_idx]:.4f})  → saved as inclusivity_best_fold.pth')\n",
    "\n",
    "print('Merging inclusivity folds...')\n",
    "merged_state = merge_folds()\n",
    "\n",
    "deploy_model = AutoModelForSequenceClassification.from_pretrained(INCL_CONFIG['model'], num_labels=1)\n",
    "deploy_model = patch_classifier_head(deploy_model, dropout=INCL_CONFIG['dropout'])\n",
    "deploy_model = deploy_model.float()\n",
    "deploy_model.load_state_dict(merged_state)\n",
    "deploy_model.eval()\n",
    "\n",
    "incl_model_dir = f'{SAVE_DIR}/inclusivity_model_dir'\n",
    "os.makedirs(incl_model_dir, exist_ok=True)\n",
    "deploy_model.save_pretrained(incl_model_dir)\n",
    "AutoTokenizer.from_pretrained(INCL_CONFIG['model']).save_pretrained(incl_model_dir)\n",
    "# Also copy best-fold weights into model_dir\n",
    "shutil.copy(incl_best_fold_save, f'{incl_model_dir}/best_fold.pth')\n",
    "print(f'Saved inclusivity model → {incl_model_dir}')\n",
    "release_memory(deploy_model, merged_state)"
   ]
