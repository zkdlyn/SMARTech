  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "83b37021",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Words in bottom 15%: ['nyc.gov.ph', 'f', 'nationalyouthcommission', 'O', 'X', '@nycpilipinas']\n",
      "{ 'details': {},\n",
      "  'label': 'Watermark OK',\n",
      "  'missing': [],\n",
      "  'pass': True,\n",
      "  'remark': 'OK'}\n"
     ]
    }
   ],
   "source": [
    "bottom_pairs = [(w, b) for w, b in zip(ocr_words, ocr_boxes) if b[1] >= 0.80]\n",
    "wm_words = [p[0] for p in bottom_pairs]\n",
    "wm_boxes = [p[1] for p in bottom_pairs]\n",
    "\n",
    "print(f'Words in bottom 15%: {wm_words}')\n",
    "\n",
    "wm_result, wm_boxes_abs = check_watermark(image, precomputed_words=wm_words, precomputed_boxes=wm_boxes)\n",
    "pp.pprint(wm_result)\n"
   ]
